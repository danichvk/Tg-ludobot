    GameType.DARTS: "🎯",
    GameType.BOWLING: "🎳"
}

# Правила игр и диапазоны значений
GAME_RULES = {
    GameType.DICE: {"emoji": "🎲", "range": (1, 6), "description": "Кто выбросит больше — тот победил!"},
    GameType.BASKETBALL: {"emoji": "🏀", "range": (1, 10), "description": "У кого больше очков — тот победил!"},
    GameType.FOOTBALL: {"emoji": "⚽", "range": (0, 5), "description": "У кого больше голов — тот победил!"},
    GameType.SLOTS: {"emoji": "🎰", "range": (0, 100), "description": "У кого больше выигрыш — тот победил!"},
    GameType.DARTS: {"emoji": "🎯", "range": (1, 10), "description": "У кого больше очков — тот победил!"},
    GameType.BOWLING: {"emoji": "🎳", "range": (0, 10), "description": "У кого больше очков — тот победил!"}
}

def get_keyboard() -> InlineKeyboardMarkup:
    """Клавиатура выбора игры"""
    keyboard = [
        [InlineKeyboardButton(f"{GAME_EMOJIS[GameType.DICE]} Кости", callback_data=f"game_{GameType.DICE}"),
         InlineKeyboardButton(f"{GAME_EMOJIS[GameType.BASKETBALL]} Баскетбол", callback_data=f"game_{GameType.BASKETBALL}")],
        [InlineKeyboardButton(f"{GAME_EMOJIS[GameType.FOOTBALL]} Футбол", callback_data=f"game_{GameType.FOOTBALL}"),
         InlineKeyboardButton(f"{GAME_EMOJIS[GameType.SLOTS]} Слоты", callback_data=f"game_{GameType.SLOTS}")],
        [InlineKeyboardButton(f"{GAME_EMOJIS[GameType.DARTS]} Дартс", callback_data=f"game_{GameType.DARTS}"),
         InlineKeyboardButton(f"{GAME_EMOJIS[GameType.BOWLING]} Боулинг", callback_data=f"game_{GameType.BOWLING}")],
        [InlineKeyboardButton("🤖 Играть с ботом", callback_data="mode_bot"),
         InlineKeyboardButton("👥 Играть с другом", callback_data="mode_player")]
    ]
    return InlineKeyboardMarkup(keyboard)

def get_opponent_keyboard(game_type: str, opponent_id: Optional[int] = None) -> InlineKeyboardMarkup:
    """Клавиатура для подтверждения игры с другим игроком"""
    keyboard = [
        [InlineKeyboardButton("✅ Принять вызов", callback_data=f"accept_{game_type}_{opponent_id}"),
         InlineKeyboardButton("❌ Отказаться", callback_data="decline")]
    ]
    return InlineKeyboardMarkup(keyboard)

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработчик команды /start"""
    welcome_text = (
        "🎮 *Добро пожаловать в игровой бот!*\n\n"
        "Доступные игры:\n"
        f"🎲 Кости (1-6)\n"
        f"🏀 Баскетбол (1-10 очков)\n"
        f"⚽ Футбол (0-5 голов)\n"
        f"🎰 Слоты (0-100 выигрыша)\n"
        f"🎯 Дартс (1-10 очков)\n"
        f"🎳 Боулинг (0-10 очков)\n\n"
        "Вы можете играть:\n"
        "• 🤖 С ботом (одиночная игра)\n"
        "• 👥 С другим игроком в чате\n\n"
        "Нажмите /play чтобы начать!"
    )
    await update.message.reply_text(welcome_text, parse_mode='Markdown')

async def play(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Команда /play - показать меню игр"""
    await update.message.reply_text(
        "🎮 *Выбери игру и режим:*",
        parse_mode='Markdown',
        reply_markup=get_keyboard()
    )

async def button_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработчик нажатий на кнопки"""
    query = update.callback_query
    await query.answer()
    
    data = query.data
    user = query.from_user
    chat_id = query.message.chat_id
    
    if data.startswith("game_"):
        game_type = data.split("_")[1]
        context.user_data['selected_game'] = game_type
        await query.edit_message_text(
            f"🎮 Выбрана игра: {GAME_RULES[game_type]['description']}\n\n"
            f"Теперь выбери режим игры:",
            reply_markup=InlineKeyboardMarkup([
                [InlineKeyboardButton("🤖 С ботом", callback_data=f"mode_bot_{game_type}"),
                 InlineKeyboardButton("👥 С другом", callback_data=f"mode_player_{game_type}")]
            ])
        )
    
    elif data.startswith("mode_bot"):
        # Игра с ботом
        if "_" in data:
            game_type = data.split("_")[2]
        else:
            game_type = context.user_data.get('selected_game', GameType.DICE)
        
        await play_with_bot(query, chat_id, user, game_type)
    
    elif data.startswith("mode_player"):
        # Игра с другим игроком
        if "_" in data:
            game_type = data.split("_")[2]
        else:
            game_type = context.user_data.get('selected_game', GameType.DICE)
        
        await challenge_player(query, chat_id, user, game_type)
    
    elif data.startswith("accept_"):
        # Принятие вызова
        parts = data.split("_")
        game_type = parts[1]
        opponent_id = int(parts[2])
        
        if user.id == opponent_id:
            await query.edit_message_text("❌ Нельзя играть с самим собой!")
            return
        
        await start_multiplayer_game(query, chat_id, user, opponent_id, game_type)
    
    elif data == "decline":
        await query.edit_message_text("❌ Вызов отклонён.")

async def play_with_bot(query, chat_id: int, user, game_type: str):
    """Одиночная игра с ботом"""
    game_key = (chat_id, 'bot')
    
    # Генерируем результаты
    user_result = random.randint(*GAME_RULES[game_type]['range'])
    bot_result = random.randint(*GAME_RULES[game_type]['range'])
    
    # Определяем победителя
    if user_result > bot_result:
        result_text = "🎉 *Ты победил!* 🎉"
        emoji = "🏆"
    elif user_result < bot_result:
        result_text = "🤖 *Бот победил!* 🤖"
        emoji = "💀"
    else:
        result_text = "🤝 *Ничья!* 🤝"
        emoji = "🤝"
    
    # Формируем сообщение с эмодзи
    game_emoji = GAME_EMOJIS[game_type]
    message = (
        f"{game_emoji} *Игра: {GAME_RULES[game_type]['emoji']} {game_type.upper()}* {game_emoji}\n\n"
        f"👤 *Твой результат:* {user_result}\n"
        f"🤖 *Результат бота:* {bot_result}\n\n"
        f"{emoji} {result_text}\n\n"
        f"Нажми /play чтобы сыграть снова!"
    )
    
    await query.edit_message_text(message, parse_mode='Markdown')

async def challenge_player(query, chat_id: int, challenger, game_type: str):
    """Вызов другого игрока на игру"""
    message = (
        f"🎮 *{challenger.first_name} вызывает тебя на игру!*\n\n"
        f"Игра: {GAME_EMOJIS[game_type]} {game_type.upper()}\n"
        f"{GAME_RULES[game_type]['description']}\n\n"
        f"Принять вызов?"
    )
    
    await query.edit_message_text(
        message,
        parse_mode='Markdown',
        reply_markup=get_opponent_keyboard(game_type, challenger.id)
    )

async def start_multiplayer_game(query, chat_id: int, player2, player1_id: int, game_type: str):
    """Начало многопользовательской игры"""
    # Получаем игрока 1 (кто вызвал)
    # В реальном боте нужно хранить состояние вызова, здесь упрощённо
    player1 = await query.message.get_user(player1_id)
    
    # Генерируем результаты
    result1 = random.randint(*GAME_RULES[game_type]['range'])
    result2 = random.randint(*GAME_RULES[game_type]['range'])
    
    # Определяем победителя
    if result1 > result2:
        winner = player1.first_name if player1 else "Игрок 1"
        result_text = f"🏆 *{winner} победил!* 🏆"
    elif result2 > result1:
        winner = player2.first_name
        result_text = f"🏆 *{winner} победил!* 🏆"
    else:
        result_text = "🤝 *Ничья!* 🤝"
    
    game_emoji = GAME_EMOJIS[game_type]
    message = (
        f"{game_emoji} *Результаты игры {game_type.upper()}* {game_emoji}\n\n"
        f"👤 *{player1.first_name if player1 else 'Игрок 1'}*: {result1}\n"
        f"👤 *{player2.first_name}*: {result2}\n\n"
        f"{result_text}\n\n"
        f"Нажми /play чтобы сыграть снова!"
    )
    
    await query.edit_message_text(message, parse_mode='Markdown')

